# Live template. Copy outside git-managed secrets storage before use.
TRADING_MODE=live
LIVE_TRADING=1
REPLAY_MODE=0

ENTRY_POLICY=TOS
EXIT_POLICY=TOS
ARB_ENABLED=0
CHAINLINK_CHECK=1

FILLS_PATH=live_fills.jsonl
EXITS_PATH=live_exits.jsonl
KILL_SWITCH_FILE=/tmp/btcbot_halt

# Conservative first-live caps. Raise only after validation.
MAX_SPEND_PER_MARKET=8
MAX_TAKER_FILL_USDC=4
MAX_LOSS_PER_HOUR_USDC=10
MAX_POSITION_SHARES=10

# Real secrets go in the deployed environment, not in git.
PRIVATE_KEY=
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=
WALLET_ADDRESS=
